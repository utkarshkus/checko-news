# Copy this file to .env and fill in your values
# These go into Netlify Environment Variables for production

# NewsAPI (newsapi.org) — free: 100 req/day
NEWS_API_KEY=your_newsapi_key_here

# GNews (gnews.io) — free: 100 req/day
GNEWS_API_KEY=your_gnews_key_here

# OpenAI (platform.openai.com)
OPENAI_API_KEY=sk-your_openai_key_here

# rss2json (optional, rss2json.com) — free tier works without key
RSS2JSON_KEY=your_rss2json_key_here
